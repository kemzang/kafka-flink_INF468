# ─────────────────────────────────────────────────────────────
# Configuration du producteur Kafka distant
# Copiez ce fichier en .env et renseignez vos valeurs
# ─────────────────────────────────────────────────────────────

# IP du PC central hébergeant Kafka (obligatoire)
CENTRAL_IP=192.168.1.100

# Port Kafka exposé sur le PC central (défaut: 9092)
KAFKA_PORT=9092

# Type de producteur (ne pas modifier pour ce dossier)
PRODUCER_TYPE=kafka

# Intervalle d'envoi en millisecondes entre chaque message (défaut: 500ms)
SEND_INTERVAL_MS=500
