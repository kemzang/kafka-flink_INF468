# ─────────────────────────────────────────────────────────────
# Configuration du producteur RabbitMQ distant
# Copiez ce fichier en .env et renseignez vos valeurs
# ─────────────────────────────────────────────────────────────

# IP du PC central hébergeant RabbitMQ (obligatoire)
CENTRAL_IP=10.134.78.146

# Port RabbitMQ AMQP exposé sur le PC central (défaut: 5672)
RABBITMQ_PORT=5672

# Identifiants RabbitMQ (doivent correspondre au docker-compose du PC central)
RABBITMQ_USER=admin
RABBITMQ_PASS=password123

# Type de producteur (ne pas modifier pour ce dossier)
PRODUCER_TYPE=rabbitmq

# Mode turbo — envoie le maximum de messages possible
TURBO_MODE=true
TURBO_THREADS=4
